# SteelOps Backend Environment Variables Example
# Copy this file to '.env' in the same directory and fill in your actual credentials.

# 1. Database Configuration (optional, defaults to sqlite:///./steelops.db)
# DATABASE_URL=sqlite:///./steelops.db

# 2. Gmail API OAuth2 Configuration
# Option A: Standard OAuth2 Local Flow
# Place your GCP console downloaded 'credentials.json' file directly in the backend/ folder.
# The server will automatically use it and prompt for browser authentication on the first run,
# which will generate a local 'token.json' file.
GMAIL_CREDENTIALS_JSON_PATH=credentials.json
GMAIL_TOKEN_JSON_PATH=token.json

# Option B: Headless Environment Variables (recommended for production/docker)
# If these variables are set, the server will bypass the browser pop-up and credentials.json file.
# GMAIL_CLIENT_ID=your_gcp_client_id.apps.googleusercontent.com
# GMAIL_CLIENT_SECRET=your_gcp_client_secret
# GMAIL_REFRESH_TOKEN=your_oauth_refresh_token
